{
	"name": "@ctx-core/auth0-spa-svelte",
	"version": "1.2.309",
	"description": "ctx-core auth0 ui component & express endpoints",
	"keywords": [
		"ctx-core",
		"auth0",
		"svelte"
	],
	"homepage": "https://github.com/ctx-core/auth0-ui#readme",
	"bugs": {
		"url": "https://github.com/ctx-core/auth0-ui/issues"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/ctx-core/auth0-spa-svelte.git"
	},
	"license": "Apache-2.0",
	"author": {
		"name": "Brian Takita",
		"url": "https://briantakita.me",
		"email": "info+ctx-core-auth0-spa-svelte@briantakita.me"
	},
	"type": "module",
	"types": "./index.d.ts",
	"exports": {
		".": "./index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"build": ":",
		"clean": ":",
		"exec": "$@",
		"prepublishOnly": "pnpm clean && pnpm build && pnpm test",
		"test": "pnpm run /^test:/",
		"test:types": "tsc --noEmit",
		"test:unit": "tsx node_modules/uvu/bin.js . '\\.test\\.(ts|js)$'",
		"disable:test:unit:coverage": "c8 pnpm test:unit"
	},
	"dependencies": {
		"@ctx-core/auth0": "*",
		"@ctx-core/auth0-ui": "^15.1.13",
		"@ctx-core/dialog-ui-svelte": "*",
		"@ctx-core/dom": "*",
		"@ctx-core/nanostores": "*",
		"auth0-js": "^9.30.1",
		"ctx-core": "*",
		"svelte": "^5.53.7"
	},
	"devDependencies": {
		"c8": "^11.0.0",
		"tsx": "^4.21.0",
		"typescript": "next",
		"uvu": "^0.5.6"
	},
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false
}